datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model Activity {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  type        String
  description String
  minGrade    Int      @map("min_grade")
  maxGrade    Int      @map("max_grade")
  lastUpdated DateTime @default(now()) @map("last_updated")

  schedules   ActivitySchedule[]
  keywords    ActivityKeyword[]

  @@map("activities")
}

model ActivitySchedule {
  id         Int    @id @default(autoincrement())
  activityId Int    @map("activity_id")
  dayOfWeek  String @map("day_of_week")
  startTime  Int?   @map("start_time")
  endTime    Int?   @map("end_time")

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("activity_schedules")
}

model ActivityKeyword {
  id         Int    @id @default(autoincrement())
  activityId Int    @map("activity_id")
  keyword    String

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("activity_keywords")
}